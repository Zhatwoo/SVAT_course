rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function adminRoleData() {
      return get(/databases/$(database)/documents/role/admin).data;
    }

    function hasAdmins() {
      return exists(/databases/$(database)/documents/role/admin);
    }

    function userProfileData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function profileSaysAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userProfileData().role == "admin";
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/role/admin)
        && (
          adminRoleData().members[request.auth.uid] == true
          || (
            request.auth.token.email != null
            && (
              adminRoleData().members[request.auth.token.email] == true
              || adminRoleData().members[request.auth.token.email.lower()] == true
            )
          )
        );
    }

    function canManageAdminContent() {
      return isAdmin() || profileSaysAdmin();
    }

    function currentUserExists() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // A blocked account is denied everywhere these helpers are applied.
    // Use .get() with a default so a MISSING isBlocked field does not error.
    function isBlocked() {
      return currentUserExists() && userProfileData().get('isBlocked', false) == true;
    }

    function hasValidAccessCode(data) {
      return data.get('accessCodeUsed', '') is string
        && data.get('accessCodeUsed', '').size() > 0;
    }

    // Enrolled = has redeemed an access code and is not blocked.
    function isEnrolled() {
      return currentUserExists()
        && hasValidAccessCode(userProfileData())
        && userProfileData().get('isBlocked', false) != true;
    }

    // Course content is readable only by admins or enrolled, active students.
    function canAccessContent() {
      return canManageAdminContent() || isEnrolled();
    }

    match /role/{roleId} {
      allow read: if isSignedIn();
      // Bootstrap: if no admin doc yet, first signed-in user can create role/admin.
      allow create: if roleId == 'admin' && !hasAdmins() && isSignedIn();
      allow update, delete: if canManageAdminContent();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || canManageAdminContent();
      // A normal owner may only ever create their own profile as a student.
      // Admins (or the very first bootstrap admin) may create any role.
      allow create: if canManageAdminContent()
        || (!hasAdmins() && isOwner(userId))
        || (isOwner(userId) && request.resource.data.role == "student");
      allow update: if canManageAdminContent()
        || (
          isOwner(userId)
          && resource.data.get('isBlocked', false) != true
          && request.resource.data.role == resource.data.role
          && request.resource.data.get('isBlocked', false) == resource.data.get('isBlocked', false)
          && request.resource.data.get('blockedReason', '') == resource.data.get('blockedReason', '')
          && (
            !('accessCodeUsed' in resource.data)
            || request.resource.data.accessCodeUsed == resource.data.accessCodeUsed
          )
        )
        || (
          isOwner(userId)
          && resource.data.get('isBlocked', false) != true
          && request.resource.data.accessCodeUsed is string
          && request.resource.data.accessCodeUsed.size() > 0
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['accessCodeUsed'])
        );
    }

    match /settings/{id} {
      allow read: if isSignedIn();
      allow write: if canManageAdminContent();
    }

    match /courses/{id} {
      allow read: if canAccessContent();
      allow write: if canManageAdminContent();
    }

    match /chapters/{id} {
      allow read: if canAccessContent();
      allow write: if canManageAdminContent();
    }

    match /episodes/{id} {
      allow read: if canAccessContent();
      allow write: if canManageAdminContent();
    }

    match /adminActivityLogs/{id} {
      allow read, write: if canManageAdminContent();
    }

    match /userSecurityEvents/{id} {
      allow read: if canManageAdminContent();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canManageAdminContent();
    }

    match /userProgress/{id} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && !isBlocked()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && !isBlocked()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    match /accessCodes/{codeId} {
      allow get: if resource.data.code == codeId
        && (
          resource.data.status == 'active'
          || (isSignedIn() && resource.data.usedByUid == request.auth.uid)
          || (
            isSignedIn()
            && resource.data.status == 'used'
            && resource.data.usedByEmail != null
            && resource.data.usedByEmail.lower() == request.auth.token.email.lower()
          )
        );
      allow list: if canManageAdminContent()
        || (isSignedIn() && resource.data.usedByUid == request.auth.uid)
        || (
          isSignedIn()
          && resource.data.usedByEmail != null
          && resource.data.usedByEmail.lower() == request.auth.token.email.lower()
        );
      allow create: if canManageAdminContent()
        && request.resource.data.status == 'active'
        && request.resource.data.code == codeId;
      allow update: if canManageAdminContent()
        || (
          isSignedIn()
          && resource.data.status == 'active'
          && resource.data.usedByUid == null
          && request.resource.data.status == 'used'
          && request.resource.data.usedByUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'usedByUid', 'usedByEmail', 'usedByDisplayName', 'usedAt'])
        );
      allow delete: if canManageAdminContent();
    }
  }
}
